{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite: dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http"
        }
      }
    },
    {
      "label": "dev: open in VS Code",
      "dependsOn": "vite: dev",
      "type": "shell",
      "command": "echo",
      "args": ["${input:openInSimpleBrowser}"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "inspector: scan dev server",
      "dependsOn": "vite: dev",
      "type": "shell",
      "command": "echo",
      "args": ["${input:scanWithInspector}"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "inspector: scan dev server (headed)",
      "dependsOn": "vite: dev",
      "type": "shell",
      "command": "echo",
      "args": ["${input:scanWithInspectorHeaded}"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    }
  ],
  "inputs": [
    {
      "id": "openInSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:4563"
    },
    {
      "id": "scanWithInspector",
      "type": "command",
      "command": "threeInspector.scanUrl",
      "args": { "url": "http://localhost:4563", "headless": true }
    },
    {
      "id": "scanWithInspectorHeaded",
      "type": "command",
      "command": "threeInspector.scanUrlHeaded",
      "args": { "url": "http://localhost:4563" }
    }
  ]
}
